# EduTrack Environment Variables
# Copy this file to .env and fill in your values

# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# ── Database ───────────────────────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL=sqlite:///edutrack.db
# Production (PostgreSQL) - uncomment and set:
# DATABASE_URL=postgresql://user:password@localhost:5432/edutrack

# ── Zoom Server-to-Server OAuth ────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_WEBHOOK_SECRET_TOKEN=your_zoom_webhook_secret_token

# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_DEFAULT_SENDER=your_gmail@gmail.com

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Attendance Settings ────────────────────────────────────────────────────────
# Minimum seconds in meeting to be marked Present (default: 3600 = 1 hour)
SESSION_DURATION_THRESHOLD=3600
